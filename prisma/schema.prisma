generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum TicketStatus {
  NEW
  ON_GOING
  PENDING
  RESOLVED
}

enum TicketType {
  TECHNICAL_ISSUE
  CONTENT_QUESTION
  AI_TUTOR_ISSUE
  ACCOUNT_ISSUE
  OTHER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tickets Ticket[]
  replies Reply[]
}

model Ticket {
  id          String       @id @default(cuid())
  ticketNo    String       @unique
  title       String
  body        String
  type        TicketType
  status      TicketStatus @default(NEW)
  priority    Priority     @default(MEDIUM)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies Reply[]
}

model Reply {
  id        String   @id @default(cuid())
  body      String
  createdAt DateTime @default(now())

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
}
